generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  name            String       @id
  displayName     String       @map("display_name")
  email           String
  team            String?
  phase           String       @default("Pending")
  ingressHost     String?      @map("ingress_host")
  configOverrides Json?        @map("config_overrides")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  auditEntries    AuditEntry[]

  @@map("tenants")
}

model AccessPolicy {
  name           String   @id
  description    String?
  tenantSelector Json?    @map("tenant_selector")
  domains        Json?
  egressRules    Json?    @map("egress_rules")
  mcpServers     Json?    @map("mcp_servers")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("access_policies")
}

model AuditEntry {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  tenant    String?
  action    String
  resource  String
  message   String
  metadata  Json?
  tenantRef Tenant?  @relation(fields: [tenant], references: [name])

  @@index([tenant])
  @@index([timestamp])
  @@map("audit_log")
}

model Skill {
  name        String
  scope       String
  team        String   @default("")
  path        String
  author      String?
  contentHash String?  @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@id([name, scope, team])
  @@map("skills")
}

model ServerMetricSnapshot {
  id               Int      @id @default(autoincrement())
  cpuPercent       Float    @map("cpu_percent")
  memoryUsedBytes  BigInt   @map("memory_used_bytes")
  memoryTotalBytes BigInt   @map("memory_total_bytes")
  storageUsedBytes BigInt   @map("storage_used_bytes")
  storageTotalBytes BigInt  @map("storage_total_bytes")
  activeTenants    Int      @default(0) @map("active_tenants")
  sampledAt        DateTime @default(now()) @map("sampled_at")

  @@index([sampledAt])
  @@map("server_metric_snapshots")
}

model TokenUsageSnapshot {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  totalTokens  Int      @default(0) @map("total_tokens")
  currency     String
  totalCost    Decimal  @db.Decimal(12, 4) @map("total_cost")
  sampledAt    DateTime @default(now()) @map("sampled_at")

  @@unique([userId, currency])
  @@index([sampledAt])
  @@map("token_usage_snapshots")
}

model GlobalBudgetSetting {
  id            Int      @id @default(1)
  currency      String
  ceilingAmount Decimal  @db.Decimal(12, 2) @map("ceiling_amount")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("global_budget_settings")
}

model AccountBudgetSetting {
  userId        String   @id @map("user_id")
  currency      String
  ceilingAmount Decimal  @db.Decimal(12, 2) @map("ceiling_amount")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("account_budget_settings")
}

model AccessToken {
  id         String   @id @default(cuid())
  name       String
  owner      String
  tokenHash  String   @unique @map("token_hash")
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@index([owner])
  @@map("access_tokens")
}

model ProviderApiKey {
  provider  String   @id
  keyValue  String   @map("key_value")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("provider_api_keys")
}
