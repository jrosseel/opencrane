    "db:push": "prisma db push"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.0.0",
    "@prisma/client": "^6.0.0",
    "express": "^5.1.0",
    "pino": "^9.6.0",
    "pino-http": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
